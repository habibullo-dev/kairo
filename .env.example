# Copy to .env and fill in. Never commit .env.

# Anthropic Messages API — required from task 7 (live client) onward.
ANTHROPIC_API_KEY=

# Voyage AI embeddings — required from phase 2 (memory).
VOYAGE_API_KEY=

# Tavily web search — required from task 9 (web tools).
TAVILY_API_KEY=

# --- Voice (Phase 7, optional) ---
# Cloud STT/TTS; only needed if voice.cloud_providers opts in.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# --- Connectors (Phase 9, optional) ---
# Google Workspace (Calendar/Gmail/Drive read + Gmail drafts). A "Desktop app" OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram notifier (send-only). Bot token from @BotFather; chat id is your numeric chat id.
# TELEGRAM_CHAT_ID here takes precedence over connectors.telegram.chat_id in settings.yaml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Kakao "send to me" notifier. REST API key from the Kakao developer console.
# KAKAO_CLIENT_SECRET is OPTIONAL — set it only if your Kakao app enabled a client secret
# (a PKCE-only app leaves it blank). KAKAO_REDIRECT_URI, if set, MUST match the port-derived
# redirect (http://127.0.0.1:<connectors.kakao.redirect_port>) or connect fails closed.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
